{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "agentTeamDisplayMode": "auto",
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash .claude/hooks/session-recovery.sh"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/track-changes.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .claude/hooks/self-review.sh"
      }
    ]
  }
}
