#!/bin/bash
# ============================================================
# PRISM — Setup v2
# ============================================================
#
# Architecture: gstack is vendored inside this playbook repo.
#   - Clone playbook ONCE → gstack included
#   - ./setup installs everything globally
#   - ./setup --project /path → add to any project
#   - ./setup --update → pull latest gstack
#
# Usage:
#   ./setup                          # Full: global + current dir
#   ./setup --project /path/to/proj  # Add to existing project
#   ./setup --update                 # Update gstack + relink all projects
#   ./setup --relink [/path]         # Refresh symlinks for a project (or cwd)
#   ./setup --uninstall              # Remove everything
#   ./setup --status                 # Check what's installed
# ============================================================

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'
BOLD='\033[1m'

FRAMEWORK_DIR="$(cd "$(dirname "$0")" && pwd)"
GLOBAL_SKILLS="$HOME/.claude/skills"
GLOBAL_COMMANDS="$HOME/.claude/commands"
GSTACK_VENDOR="$FRAMEWORK_DIR/vendor/gstack"

log_step()  { echo -e "\n${BLUE}▸${NC} ${BOLD}$1${NC}"; }
log_ok()    { echo -e "  ${GREEN}✓${NC} $1"; }
log_warn()  { echo -e "  ${YELLOW}⚠${NC} $1"; }
log_err()   { echo -e "  ${RED}✗${NC} $1"; }
log_info()  { echo -e "  ${BLUE}ℹ${NC} $1"; }

PRISM_SHARED="$HOME/.prism"

# ============================================================
# Shared location: ~/.prism/ (symlink source for all projects)
# ============================================================

populate_prism_shared() {
    log_step "Populating ~/.prism/ shared commands..."
    mkdir -p "$PRISM_SHARED/commands"

    # Copy commands to shared location
    if [ -d "$FRAMEWORK_DIR/.claude/commands" ]; then
        cp "$FRAMEWORK_DIR/.claude/commands"/*.md "$PRISM_SHARED/commands/" 2>/dev/null || true
    fi

    # Write version
    local ver
    ver=$(git -C "$FRAMEWORK_DIR" describe --tags 2>/dev/null || git -C "$FRAMEWORK_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    echo "$ver" > "$PRISM_SHARED/version"

    # Store source path for /prism-upgrade
    echo "$FRAMEWORK_DIR" > "$PRISM_SHARED/source-path"

    local cmd_count
    cmd_count=$(ls "$PRISM_SHARED/commands"/*.md 2>/dev/null | wc -l | tr -d ' ')
    log_ok "~/.prism/commands/ refreshed ($cmd_count commands, version: $ver)"
}

relink_project() {
    local P="$1"
    [ -d "$P/.claude/commands" ] || { mkdir -p "$P/.claude/commands"; }

    local linked=0 skipped=0

    # Create symlinks for each PRISM command
    for f in "$PRISM_SHARED/commands"/*.md; do
        [ -f "$f" ] || continue
        local base
        base=$(basename "$f")
        local target="$P/.claude/commands/$base"

        # Skip if real file (custom project command) — don't overwrite
        if [ -f "$target" ] && [ ! -L "$target" ]; then
            skipped=$((skipped + 1))
            continue
        fi

        ln -sf "$f" "$target"
        linked=$((linked + 1))
    done

    # Remove stale symlinks (command deleted from PRISM)
    for f in "$P/.claude/commands"/*.md; do
        [ -L "$f" ] || continue
        local link_target
        link_target=$(readlink "$f")
        if [ ! -f "$link_target" ]; then
            rm "$f"
            log_info "  Removed stale: $(basename "$f")"
        fi
    done

    log_ok "$(basename "$P"): $linked linked, $skipped custom preserved"
}

register_project() {
    local P="$1"
    local REG="$PRISM_SHARED/projects.list"
    mkdir -p "$PRISM_SHARED"
    touch "$REG"
    grep -qxF "$P" "$REG" 2>/dev/null || echo "$P" >> "$REG"
}

relink_all_projects() {
    local REG="$PRISM_SHARED/projects.list"
    [ -f "$REG" ] || return 0

    log_step "Relinking registered projects..."
    while IFS= read -r proj || [ -n "$proj" ]; do
        [ -z "$proj" ] && continue
        if [ -d "$proj" ]; then
            relink_project "$proj"
            # Update .prism-source marker
            echo "prism-playbook $(cat "$PRISM_SHARED/version" 2>/dev/null || echo 'unknown')" > "$proj/.prism-source" 2>/dev/null || true
        else
            log_warn "Skipped (not found): $proj"
        fi
    done < "$REG"
}

# ============================================================
# Step 1: Ensure vendor/gstack exists
# ============================================================

init_vendor() {
    log_step "Checking vendor/gstack..."

    if [ -f "$GSTACK_VENDOR/setup" ]; then
        log_ok "gstack vendored at vendor/gstack/"
        return 0
    fi

    # Try git submodule first
    if [ -f "$FRAMEWORK_DIR/.gitmodules" ] && grep -q "gstack" "$FRAMEWORK_DIR/.gitmodules" 2>/dev/null; then
        log_info "Initializing git submodule..."
        cd "$FRAMEWORK_DIR"
        git submodule update --init --recursive vendor/gstack 2>/dev/null
        if [ -f "$GSTACK_VENDOR/setup" ]; then
            log_ok "gstack submodule initialized"
            return 0
        fi
    fi

    # Fallback: clone
    log_info "Cloning gstack from GitHub..."
    mkdir -p "$FRAMEWORK_DIR/vendor"
    if git clone --quiet --depth 1 https://github.com/garrytan/gstack.git "$GSTACK_VENDOR" 2>/dev/null; then
        log_ok "gstack cloned (shallow)"
    else
        log_err "Clone failed. Check internet. Manual: git clone https://github.com/garrytan/gstack.git vendor/gstack"
        return 1
    fi
}

# ============================================================
# Step 2: Install globally
# ============================================================

install_global() {
    log_step "Installing PRISM skills → $GLOBAL_SKILLS/"
    mkdir -p "$GLOBAL_SKILLS" "$GLOBAL_COMMANDS" "$HOME/.claude"

    for skill_dir in "$FRAMEWORK_DIR/skills"/*/; do
        [ -d "$skill_dir" ] || continue
        skill_name=$(basename "$skill_dir")
        cp -r "$skill_dir" "$GLOBAL_SKILLS/$skill_name"
        log_ok "$skill_name"
    done

    if [ -d "$FRAMEWORK_DIR/.claude/commands" ]; then
        cp "$FRAMEWORK_DIR/.claude/commands"/*.md "$GLOBAL_COMMANDS/" 2>/dev/null || true
        log_ok "PRISM commands ($(ls "$FRAMEWORK_DIR/.claude/commands"/*.md 2>/dev/null | wc -l | tr -d ' ') slash commands)"
    elif [ -d "$FRAMEWORK_DIR/commands" ]; then
        cp "$FRAMEWORK_DIR/commands"/*.md "$GLOBAL_COMMANDS/" 2>/dev/null || true
        log_ok "PRISM commands"
    fi

    # --- gstack ---
    log_step "Installing gstack → $GLOBAL_SKILLS/gstack/"

    if [ -d "$GSTACK_VENDOR" ] && [ -f "$GSTACK_VENDOR/setup" ]; then
        [ -n "$GLOBAL_SKILLS" ] && [ -d "$GLOBAL_SKILLS/gstack" ] && rm -rf "$GLOBAL_SKILLS/gstack"
        cp -Rf "$GSTACK_VENDOR" "$GLOBAL_SKILLS/gstack"
        rm -rf "$GLOBAL_SKILLS/gstack/.git"

        cd "$GLOBAL_SKILLS/gstack"
        chmod +x ./setup
        if ./setup 2>/dev/null; then
            log_ok "gstack ready (browse binary + symlinks)"
        else
            log_warn "gstack setup had issues — try: cd ~/.claude/skills/gstack && bun install && bun run build"
        fi
        cd "$FRAMEWORK_DIR"

        for s in plan-ceo-review plan-eng-review review ship browse qa retro setup-browser-cookies document-release; do
            if [ -L "$GLOBAL_SKILLS/$s" ] || [ -d "$GLOBAL_SKILLS/gstack/$s" ]; then
                log_ok "  /$s"
            fi
        done
    else
        log_warn "vendor/gstack not found — run ./setup --update"
    fi

    # Settings
    if [ ! -f "$HOME/.claude/settings.json" ]; then
        cp "$FRAMEWORK_DIR/.claude/settings.json" "$HOME/.claude/settings.json"
        log_ok "Global settings.json"
    fi

    # Superpowers
    log_step "Superpowers plugin"
    log_info "Install in Claude Code: /plugin marketplace add obra/superpowers"
}

# ============================================================
# Step 3: Project interview — generate .prism/ from answers
# ============================================================

interview_project() {
    local P="$1"
    local TODAY
    TODAY=$(date +%Y-%m-%d)

    log_step "Quick project interview (30 seconds — or Enter to skip each)"

    # Q1: Project name
    echo -ne "  ${BOLD}Project name${NC} [$(basename "$P")]: "
    read -r PROJECT_NAME
    PROJECT_NAME="${PROJECT_NAME:-$(basename "$P")}"

    # Q2: Description
    echo -ne "  ${BOLD}What does it do?${NC} (1 sentence): "
    read -r PROJECT_DESC
    PROJECT_DESC="${PROJECT_DESC:-[Describe your project here]}"

    # Q3: Audience
    echo -ne "  ${BOLD}Who uses it?${NC} (e.g. internal team, end users, developers): "
    read -r PROJECT_AUDIENCE
    PROJECT_AUDIENCE="${PROJECT_AUDIENCE:-[Define your target users]}"

    # Q4: Tech stack
    echo -ne "  ${BOLD}Tech stack?${NC} (e.g. Python/FastAPI, React/Next.js): "
    read -r TECH_STACK
    TECH_STACK="${TECH_STACK:-[Define your tech stack]}"

    # Q5: Domain terms
    echo -ne "  ${BOLD}Domain-specific terms?${NC} (term1:definition, term2:definition — or skip): "
    read -r DOMAIN_TERMS

    # Q6: CLAUDE.md template
    echo ""
    echo -e "  ${BOLD}CLAUDE.md template:${NC}"
    echo "    1) Minimal    — quick start, any project"
    echo "    2) Web App    — frontend + full-stack"
    echo "    3) API        — REST/GraphQL backend"
    echo "    4) Data       — ETL, analytics, pipelines"
    echo "    5) Non-Code   — reports, strategy, docs"
    echo -ne "  ${BOLD}Choose [1-5]${NC} [1]: "
    read -r TEMPLATE_CHOICE
    TEMPLATE_CHOICE="${TEMPLATE_CHOICE:-1}"

    local TEMPLATE_FILE
    case "$TEMPLATE_CHOICE" in
        2) TEMPLATE_FILE="claude-web-app.md" ;;
        3) TEMPLATE_FILE="claude-api-backend.md" ;;
        4) TEMPLATE_FILE="claude-data-pipeline.md" ;;
        5) TEMPLATE_FILE="claude-non-code.md" ;;
        *) TEMPLATE_FILE="claude-minimal.md" ;;
    esac

    # Generate CLAUDE.md from template with project context
    # Escape sed delimiter in user input to prevent injection
    local safe_name="${PROJECT_NAME//|/\\|}"
    local safe_desc="${PROJECT_DESC//|/\\|}"
    local safe_audience="${PROJECT_AUDIENCE//|/\\|}"
    local safe_stack="${TECH_STACK//|/\\|}"
    sed -e "s|{{PROJECT_NAME}}|${safe_name}|g" \
        -e "s|{{PROJECT_DESCRIPTION}}|${safe_desc}|g" \
        -e "s|{{PROJECT_AUDIENCE}}|${safe_audience}|g" \
        -e "s|{{TECH_STACK}}|${safe_stack}|g" \
        "$FRAMEWORK_DIR/templates/$TEMPLATE_FILE" > "$P/CLAUDE.md"
    log_ok "CLAUDE.md (${TEMPLATE_FILE%.md})"

    # Generate CONTEXT_HUB.md (use quoted heredoc to prevent shell injection)
    cat > "$P/.prism/CONTEXT_HUB.md" << 'CONTEXT_EOF'
# CONTEXT HUB — Shared Project Context

> Single Source of Truth for all agents.
> Master-Agent updates. Sub-agents read only.

## WHY — Why this project exists

__PROJECT_DESC__

## WHO — Who receives the output

- **Primary**: __PROJECT_AUDIENCE__
- **Secondary**: [Add as needed]

## STANDARDS — Output standards

### Code Standards
- Language: __TECH_STACK__
- Style: [Define your coding conventions]
- Testing: [Define your testing approach]
- Naming: [Define naming conventions]

### Document Standards
- Format: GitHub-flavored Markdown
- All docs must match actual code/behavior (no stale docs)

### Quality Gates
- [Define your quality criteria]

## TECH STACK

- **Core**: __TECH_STACK__
- [Add frameworks, tools, services as needed]

## KEY CONSTRAINTS

- [Add project constraints, deadlines, limitations]

---
*Last updated: __TODAY__*
*Updated by: Master-Agent*
CONTEXT_EOF
    # Safe substitution after heredoc (no shell expansion)
    sed -i '' \
        -e "s|__PROJECT_DESC__|${PROJECT_DESC//|/\\|}|g" \
        -e "s|__PROJECT_AUDIENCE__|${PROJECT_AUDIENCE//|/\\|}|g" \
        -e "s|__TECH_STACK__|${TECH_STACK//|/\\|}|g" \
        -e "s|__TODAY__|${TODAY}|g" \
        "$P/.prism/CONTEXT_HUB.md"

    # Generate MASTER_PLAN.md (use quoted heredoc to prevent shell injection)
    cat > "$P/.prism/MASTER_PLAN.md" << 'PLAN_EOF'
# MASTER PLAN

> Managed by Master-Agent. Reviewed by Human.
> Updated after each task completion.

## Current Sprint

**Sprint**: #1 — Project Setup
**Goal**: __PROJECT_NAME__ — Initial setup and first deliverable
**Status**: 🔄 In progress

## Task Board

| ID | Task | Model Tier | Status | Deps | Notes |
|----|------|-----------|--------|------|-------|
| | | | | | |

### Status Legend
- ⏳ Not started
- 🔄 In progress
- ✅ Done
- ❌ Blocked
- 🔁 Needs revision

## Completed Tasks Log

| ID | Completed | Summary | Files Changed |
|----|-----------|---------|---------------|

## Blockers & Issues

| Issue | Severity | Owner | Status |
|-------|----------|-------|--------|

---
*Last updated: __TODAY__*
PLAN_EOF
    # Safe substitution after heredoc
    sed -i '' \
        -e "s|__PROJECT_NAME__|${PROJECT_NAME//|/\\|}|g" \
        -e "s|__TODAY__|${TODAY}|g" \
        "$P/.prism/MASTER_PLAN.md"

    # Generate DICTIONARY.md with domain terms
    cat > "$P/.prism/DICTIONARY.md" << 'DICT_EOF'
# PROJECT DICTIONARY

> Defines project-specific terminology.
> Purpose: AI never guesses meaning.
> Updated by: Master-Agent + Human

## PRISM Terms

| Term | Definition | Context |
|------|-----------|---------|
| `PRISM` | Plan → Review → Implement → Ship → Monitor | Core playbook lifecycle |
| `Master-Agent` | The orchestrator that plans, decomposes, delegates, reviews | Opus-tier, runs in main session |
| `Sub-Agent` | Focused executor that reads a task brief and delivers | Sonnet-tier, runs in separate session |
| `GSD` | Get Shit Done — do it yourself if task < 15 min | Quick strike mode, no sub-agent needed |
| `DoD` | Definition of Done — specific, verifiable completion criteria | Every task must have one |
| `Context Compacting` | Extracting essential state into STAGING.md for session handoff | When conversation gets too long |

## Project Terms

| Term | Definition | Context |
|------|-----------|---------|
DICT_EOF

    if [ -n "$DOMAIN_TERMS" ]; then
        IFS=',' read -ra TERMS <<< "$DOMAIN_TERMS"
        for entry in "${TERMS[@]}"; do
            entry=$(echo "$entry" | sed 's/^ *//;s/ *$//')
            local term="${entry%%:*}"
            local def="${entry#*:}"
            term=$(echo "$term" | sed 's/^ *//;s/ *$//')
            def=$(echo "$def" | sed 's/^ *//;s/ *$//')
            if [ -n "$term" ] && [ -n "$def" ]; then
                echo "| \`${term}\` | ${def} | Project-specific |" >> "$P/.prism/DICTIONARY.md"
            fi
        done
    else
        echo "| | [Add terms as they arise] | |" >> "$P/.prism/DICTIONARY.md"
    fi

    cat >> "$P/.prism/DICTIONARY.md" << 'DICT_FOOTER'

---
*Append new terms as they arise. Never rewrite entire file.*
DICT_FOOTER

    # Copy knowledge templates
    cp "$FRAMEWORK_DIR/.prism-template/knowledge/RULES.md" "$P/.prism/knowledge/RULES.md"
    cp "$FRAMEWORK_DIR/.prism-template/knowledge/GOTCHAS.md" "$P/.prism/knowledge/GOTCHAS.md"
    cp "$FRAMEWORK_DIR/.prism-template/knowledge/TECH_DECISIONS.md" "$P/.prism/knowledge/TECH_DECISIONS.md"

    log_ok ".prism/ generated for \"${PROJECT_NAME}\""
}

# ============================================================
# Step 4: Setup project
# ============================================================

setup_project() {
    local P="$1"
    log_step "Setting up project → $P/"

    [ -d "$P" ] || { log_err "Not found: $P"; return 1; }

    # .claudecodeignore (don't overwrite existing)
    if [ ! -f "$P/.claudecodeignore" ]; then
        cp "$FRAMEWORK_DIR/.claudecodeignore" "$P/.claudecodeignore"
        log_ok ".claudecodeignore"
    else
        log_info ".claudecodeignore exists — skipped"
    fi

    # .prism/ — create structure
    local prism_existed=false
    [ -d "$P/.prism" ] && prism_existed=true
    for d in tasks adhoc templates knowledge context designs qa-reports retros brainstorms; do
        mkdir -p "$P/.prism/$d"
    done
    log_ok ".prism/ structure"

    # Interview to generate CLAUDE.md + .prism/ content (only for new projects)
    if [ "$prism_existed" = false ]; then
        interview_project "$P"
    else
        if [ ! -f "$P/CLAUDE.md" ]; then
            log_info ".prism/ exists but no CLAUDE.md — running interview for CLAUDE.md"
            interview_project "$P"
        else
            log_info "CLAUDE.md + .prism/ exist — skipped interview"
        fi
    fi

    # .claude/settings.json + commands
    mkdir -p "$P/.claude/commands"
    [ ! -f "$P/.claude/settings.json" ] && cp "$FRAMEWORK_DIR/.claude/settings.json" "$P/.claude/settings.json"
    log_ok ".claude/settings.json"

    # Slash commands — symlink from ~/.prism/commands/
    if [ -d "$PRISM_SHARED/commands" ]; then
        relink_project "$P"
    elif [ -d "$FRAMEWORK_DIR/.claude/commands" ]; then
        # Fallback: copy if ~/.prism/ not populated yet
        cp "$FRAMEWORK_DIR/.claude/commands"/*.md "$P/.claude/commands/" 2>/dev/null || true
        log_ok ".claude/commands/ (copied — run ./setup to enable symlinks)"
    fi

    # Register project for auto-relink on updates
    register_project "$P"

    # Source marker
    echo "prism-playbook $(cat "$PRISM_SHARED/version" 2>/dev/null || echo 'unknown')" > "$P/.prism-source" 2>/dev/null || true

    # Vendor gstack into project?
    echo ""
    echo -e "  ${YELLOW}Vendor gstack into this project so teammates get it via git?${NC}"
    echo -e "  (They'll only need to run: cd .claude/skills/gstack && ./setup)"
    echo -ne "  ${BOLD}[y/N]:${NC} "
    read -r REPLY
    if [[ "$REPLY" =~ ^[Yy]$ ]]; then
        if [ -d "$GSTACK_VENDOR" ]; then
            mkdir -p "$P/.claude/skills"
            cp -Rf "$GSTACK_VENDOR" "$P/.claude/skills/gstack"
            rm -rf "$P/.claude/skills/gstack/.git"
            log_ok "gstack vendored → .claude/skills/gstack/"
            log_info "Teammates: cd .claude/skills/gstack && ./setup"
        fi
    else
        log_info "Skipped — teammates need global gstack install"
    fi
}

# ============================================================
# Update
# ============================================================

update_all() {
    log_step "Updating vendor/gstack..."

    if [ -d "$GSTACK_VENDOR/.git" ]; then
        cd "$GSTACK_VENDOR" && git pull --quiet && cd "$FRAMEWORK_DIR"
        log_ok "vendor/gstack updated"
    else
        [ -n "$GSTACK_VENDOR" ] && rm -rf "$GSTACK_VENDOR"
        git clone --quiet --depth 1 https://github.com/garrytan/gstack.git "$GSTACK_VENDOR"
        log_ok "vendor/gstack re-cloned"
    fi

    install_global
    populate_prism_shared
    relink_all_projects
    log_ok "Update complete"
}

# ============================================================
# Status
# ============================================================

check_status() {
    log_step "Status"

    echo -e "\n  ${BOLD}Framework repo:${NC}"
    [ -f "$FRAMEWORK_DIR/CLAUDE.md" ] && log_ok "CLAUDE.md" || log_err "CLAUDE.md"
    [ -d "$FRAMEWORK_DIR/skills" ] && log_ok "skills/" || log_err "skills/"
    [ -f "$GSTACK_VENDOR/setup" ] && log_ok "vendor/gstack/" || log_warn "vendor/gstack/ (run --update)"

    echo -e "\n  ${BOLD}Global installs (~/.claude/skills/):${NC}"
    for s in master-agent sub-agent context-compactor knowledge-spine gstack-bridge cost-tracker qa-engineer paranoid-review ship-engineer sprint-retro design-auditor browser-agent; do
        [ -d "$GLOBAL_SKILLS/$s" ] && log_ok "$s" || log_warn "$s"
    done
    [ -d "$GLOBAL_SKILLS/gstack" ] && log_ok "gstack" || log_warn "gstack"

    echo -e "\n  ${BOLD}gstack skills:${NC}"
    for s in plan-ceo-review plan-eng-review review ship browse qa retro setup-browser-cookies document-release; do
        [ -L "$GLOBAL_SKILLS/$s" ] && log_ok "/$s" || log_warn "/$s"
    done

    echo -e "\n  ${BOLD}Shared (~/.prism/):${NC}"
    if [ -f "$PRISM_SHARED/version" ]; then
        log_ok "version: $(cat "$PRISM_SHARED/version")"
    else
        log_warn "~/.prism/version (run ./setup to initialize)"
    fi
    if [ -d "$PRISM_SHARED/commands" ]; then
        local shared_count
        shared_count=$(ls "$PRISM_SHARED/commands"/*.md 2>/dev/null | wc -l | tr -d ' ')
        log_ok "commands/ ($shared_count files)"
    else
        log_warn "~/.prism/commands/ (run ./setup to initialize)"
    fi

    if [ -f "$PRISM_SHARED/projects.list" ]; then
        local proj_count
        proj_count=$(wc -l < "$PRISM_SHARED/projects.list" | tr -d ' ')
        log_ok "projects.list ($proj_count registered)"
        echo -e "\n  ${BOLD}Registered projects:${NC}"
        while IFS= read -r proj || [ -n "$proj" ]; do
            [ -z "$proj" ] && continue
            if [ -d "$proj/.claude/commands" ]; then
                local sym real
                sym=$(find "$proj/.claude/commands" -maxdepth 1 -type l -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
                real=$(find "$proj/.claude/commands" -maxdepth 1 -not -type l -name "*.md" -not -type d 2>/dev/null | wc -l | tr -d ' ')
                log_ok "$(basename "$proj"): $sym linked, $real custom"
            else
                log_warn "$(basename "$proj"): not found"
            fi
        done < "$PRISM_SHARED/projects.list"
    else
        log_info "No projects registered yet (run ./setup --project /path)"
    fi

    echo -e "\n  ${BOLD}Tools:${NC}"
    command -v claude &>/dev/null && log_ok "Claude Code" || log_warn "Claude Code"
    command -v git &>/dev/null && log_ok "Git" || log_err "Git"
    command -v bun &>/dev/null && log_ok "Bun" || log_warn "Bun (for /browse)"
}

# ============================================================
# Uninstall
# ============================================================

uninstall_all() {
    log_step "Uninstalling..."
    for s in master-agent sub-agent context-compactor knowledge-spine gstack-bridge cost-tracker qa-engineer paranoid-review ship-engineer sprint-retro design-auditor browser-agent; do
        rm -rf "$GLOBAL_SKILLS/$s" 2>/dev/null && log_ok "Removed $s"
    done
    for s in browse plan-ceo-review plan-eng-review review ship retro qa qa-only setup-browser-cookies document-release gstack-upgrade; do
        rm -f "$GLOBAL_SKILLS/$s" 2>/dev/null
    done
    rm -rf "$GLOBAL_SKILLS/gstack" 2>/dev/null && log_ok "Removed gstack"
    rm -f "$GLOBAL_COMMANDS"/commands.md 2>/dev/null && log_ok "Removed commands"
    echo ""
    log_warn "Project files (CLAUDE.md, .prism/) NOT removed — delete manually per project."
    log_ok "Done"
}

# ============================================================
# Summary
# ============================================================

print_summary() {
    echo ""
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD} PRISM — Installed${NC}"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e " ${BOLD}Add to another project:${NC}"
    echo -e "   ./setup --project ~/projects/my-other-app"
    echo ""
    echo -e " ${BOLD}Update dependencies:${NC}"
    echo -e "   ./setup --update"
    echo ""
    echo -e " ${BOLD}Start working:${NC}"
    echo -e "   cd your-project && claude"
    echo -e "   > /ceo-review → /eng-review → /plan → GO"
    echo -e "   > /paranoid-review → /ship-it → /document-release → /qa-check → /retro"
    echo ""
    echo -e " ${BOLD}Docs:${NC} GETTING-STARTED.md"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ============================================================
# Main
# ============================================================

echo -e "\n${BOLD}PRISM — Setup v2${NC}"

case "${1:-}" in
    --project)   populate_prism_shared; setup_project "$(cd "${2:-.}" && pwd)"; print_summary ;;
    --update)    update_all ;;
    --relink)    populate_prism_shared; relink_project "$(cd "${2:-.}" && pwd)" ;;
    --status)    check_status ;;
    --uninstall) uninstall_all ;;
    --help|-h)
        echo -e "\nUsage: ./setup [option]\n"
        echo "  (no args)                Full install: global + current dir"
        echo "  --project /path          Add playbook to existing project"
        echo "  --update                 Update gstack + relink all projects"
        echo "  --relink [/path]         Refresh symlinks for a project (or cwd)"
        echo "  --status                 Check installation status"
        echo "  --uninstall              Remove all global installs"
        echo "  --help                   Show this help"
        ;;
    *)
        log_step "Prerequisites..."
        command -v git &>/dev/null && log_ok "Git" || { log_err "Git required"; exit 1; }
        command -v claude &>/dev/null && log_ok "Claude Code" || log_warn "Claude Code not found"
        command -v bun &>/dev/null && log_ok "Bun" || log_warn "Bun not found (for /browse)"
        init_vendor
        install_global
        populate_prism_shared
        setup_project "$(pwd)"
        print_summary
        ;;
esac
